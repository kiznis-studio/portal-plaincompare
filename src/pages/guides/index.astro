---
export const prerender = false;
import Base from '../../layouts/Base.astro';

const guides = [
  { slug: 'how-to-compare-cities', title: 'How to Compare Cities with Data', description: 'A framework for evaluating metros across cost of living, safety, education, jobs, health, and environment using federal data sources.' },
  { slug: 'what-metro-data-tells-you', title: 'What Metro-Level Data Tells You', description: 'Understanding metropolitan statistical areas, why they matter more than city limits, and what each data dimension reveals.' },
  { slug: 'data-driven-relocation', title: 'Data-Driven Relocation Decisions', description: 'How to use PlainCompare\'s multi-source data to evaluate potential cities before making a move.' },
  { slug: 'how-to-use-data-for-relocation-decisions', title: 'How to Use Data for Relocation Decisions', description: 'Practical guide to using multi-factor federal data — cost, crime, schools, jobs, climate — to evaluate cities with an 8-factor framework.' },
  { slug: 'fastest-growing-metros-in-america', title: 'Fastest-Growing Metros in America', description: 'Data ranking of U.S. metros by population, job, and income growth. Top 15 fastest-growing metros and what is driving their expansion.' },
  { slug: 'remote-work-relocation-data', title: 'Remote Work and Relocation: What the Data Says', description: 'How geographic arbitrage works, which metros offer the best purchasing power for remote workers, and how to use BEA, HUD, BLS, and FBI data to evaluate a move.' },
];
---

<Base title="City Comparison Guides — PlainCompare" description="Guides on comparing cities, understanding metro data, and making data-driven relocation decisions using federal data.">
  <div class="mx-auto max-w-4xl px-4 py-8 md:py-12">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-3">City Comparison Guides</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-2xl">
      Learn how to use multi-source federal data to compare cities objectively.
      These guides cover the seven dimensions PlainCompare draws from — cost of
      living (BEA), rent (HUD), crime (FBI), jobs (BLS), schools (NCES),
      childcare (DOL), and environment (EPA) — and show you how to weigh
      each factor for a data-driven relocation decision across 384 metros.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {guides.map(g => (
        <a href={`/guides/${g.slug}`} class="block p-6 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-indigo-400 dark:hover:border-indigo-500 transition-colors">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">{g.title}</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400">{g.description}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
